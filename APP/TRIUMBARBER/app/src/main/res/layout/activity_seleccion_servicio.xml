<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECCIONA UN SERVICIO"
        android:textColor="#D4AF37"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnServicioCorte"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="CORTE (30 min)"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnServicioBarba"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="BARBA (30 min)"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnServicioCorteBarba"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="CORTE + BARBA (1 hora)"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnServicioDecoloracion"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="DECOLORACIÓN (Especial)"
        android:backgroundTint="#D4AF37"
        android:textColor="#000000"
        android:layout_marginBottom="12dp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="* La decoloración reserva 2 bloques de 30 min, deja 1 hora libre y reserva otros 2 bloques."
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="10dp"/>

</LinearLayout>